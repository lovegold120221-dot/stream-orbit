# ─── Orbit Meeting Environment Variables ───
# Copy to .env.local and fill in your values.

# LiveKit Cloud / Server
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Supabase (project settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Gemini API key (used by the Python translator agent)
# GEMINI_API_KEY=your-gemini-api-key

# ─── macOS Code Signing (GitHub Secrets — NOT dotenv) ───
# These go in GitHub repo Settings > Secrets and variables > Actions, NOT .env files:
#
#   MACOS_CERTIFICATE_P12_BASE64    — base64 of Developer ID Application .p12
#   MACOS_CERTIFICATE_PASSWORD      — password for the .p12
#   APPLE_ID                       — Apple Developer account email
#   APPLE_APP_SPECIFIC_PASSWORD     — App-specific password (appleid.apple.com)
#   APPLE_TEAM_ID                  — Team ID from developer.apple.com
#
# How to export your certificate:
#   security find-identity -v -p codesigning                     # list identities
#   security export -k ~/Library/Keychains/login.keychain \
#     -t identities -f pkcs12 -o developer-id.p12               # export
#   base64 -i developer-id.p12 -o developer-id.b64              # encode
#   pbcopy < developer-id.b64                                   # copy to clipboard
# Then paste into GitHub secret MACOS_CERTIFICATE_P12_BASE64.
